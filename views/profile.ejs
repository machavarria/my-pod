<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Podcast AI Companion</title>
    <link rel="stylesheet" href="//netdna.bootstrapcdn.com/bootstrap/3.0.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="//netdna.bootstrapcdn.com/font-awesome/4.0.3/css/font-awesome.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body>
<div class="container-fluid">

  <aside class="menu">
    <h2 class="title">Podcast AI Companion</h2>

    <section class="top-podcasts">
      <h3>Top Podcasts</h3>
      <ul>
        <li>The AI Breakdown <button class="follow-btn">Follow</button></li>
        <li>Tech Talk Daily <button class="follow-btn">Follow</button></li>
        <li>Dev Chats <button class="follow-btn">Follow</button></li>
      </ul>
    </section>

    <div class="dash">
      <a href="/logout" class="profile logout">Sign Out</a>
    </div>

  </aside>

  <main class="createSpace">

    <header class="projectHeader">
      <h1>Dashboard</h1>
      <p class="paste">Paste your podcast transcript or upload audio to generate a summary.</p>
    </header>

    <section class="panel">
      <form action="/summarize" method="POST" enctype="multipart/form-data" class="composer">
        <label class="newSummary"></label>
        <textarea name="transcript" placeholder="Paste transcript here." rows="6"></textarea>
        <input type="file" name="audioFile" accept="audio/*">
        <button type="submit">Create Summary</button>
      </form>
    </section>

    <% if (latestSummary) { %>
    <section class="block">
      <div class="result">
        <h3>Latest Summary:</h3>
        <p><%= latestSummary %></p>

        <button class="copy-summary" data-text="<%= latestSummary %>">Copy Summary</button>

        <% if (latestHashtags && latestHashtags.length > 0) { %>
          <div class="hashtags">
            <% latestHashtags.forEach(tag => { %> 
            <span class="tag"><%= tag %></span>
            <% }) %>
          </div>
        <% } %>

        <div class="related-podcasts">
          <h3>Related Podcasts:</h3>
          <div class="podcast-grid"></div>
        </div>

      </div>
    </section>
    <% } %>


    <section class="block">
      <h2>Past Summaries</h2>

      <input type="text" id="search-summaries" placeholder="Search summaries" class="search">

      <div class="scroll">
        <% if (summaries && summaries.length > 0) { %>
          <% summaries.forEach(s => { %> 
            <div class="feed" data-id="<%= s._id %>">
              <strong><%= new Date(s.dateOfSummary).toLocaleDateString() %>:</strong>
              <p><%= s.summary %></p>

              <button class="copy-summary" data-text="<%= s.summary %>">Copy</button>
              <button class="delete-summary">Delete</button>

              <div class="rating">
                <% for (let i = 1; i <=5; i++) { %>
                <i class="fa fa-star rating-star <%= (s.rating && s.rating >= i) ? 'active' : '' %>" data-value="<%= i %>"></i>
                <% } %>
              </div>

              <% if (s.hashtags && s.hashtags.length > 0) { %>
              <div class="hashtags">
                <% s.hashtags.forEach(tag => { %> 
                <span class="tag"><%= tag %></span>
               <% }) %>
              </div>
             <% } %>
            </div>
       <% }) %>
       <% } else { %> 
        <p>No past summaries yet? Start creating one above!</p>
       <% } %>
      </div>
    </section>

  </main>
</div>


<script src="main.js"></script>

</body>
</html>
